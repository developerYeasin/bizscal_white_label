<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Receipt</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- QR Code Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            -webkit-print-color-adjust: exact;
            color-adjust: exact;
        }
        @media print {
            .no-print { display: none !important; }
            body { background-color: #ffffff; }
            .print-container { box-shadow: none; margin: 0; max-width: 100%; border: none; }
        }
    </style>
</head>
<body class="p-4">
    <div class="print-container max-w-xs mx-auto bg-white p-6">
        <header class="text-center pb-6 mb-8 border-b border-dashed border-gray-400">
            <img src="<%= it.invoiceData.logo %>" alt="Company Logo" class="w-24 mx-auto mb-4" onerror="this.onerror=null; this.src='<%= it.invoiceData.logo %>';">
        </header>
        <section class="mb-8">
            <div class="flex justify-between text-sm text-gray-600">
                <p><strong>Invoice #:</strong> <%= it.invoiceData.invoiceNumber %></p>
                <p><strong>Date:</strong> <%= it.invoiceData.date %></p>
            </div>
            <div class="mt-4">
                <p class="text-sm text-gray-600"><strong>Bill To:</strong> <%= it.invoiceData.customerName %></p>
            </div>
        </section>
        <section>
            <div class="flow-root">
                <table class="min-w-full">
                    <tbody class="bg-white">
                        <% it.invoiceData.items.forEach(function(item){ %>
                        <tr class="border-b border-dashed border-gray-300">
                            <td class="py-2 whitespace-nowrap">
                                <p class="text-sm font-medium text-gray-900"><%= item.name %></p>
                                <p class="text-xs text-gray-500">Qty: <%= item.quantity %> @ $<%= item.price.toFixed(2) %></p>
                            </td>
                            <td class="py-2 text-right text-sm font-medium text-gray-800">
                                $<%= (item.quantity * item.price).toFixed(2) %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </section>
        <section class="mt-8">
            <div class="space-y-2">
                <div class="flex justify-between text-sm text-gray-600">
                    <span>Subtotal</span>
                    <span>$<%= it.invoiceData.items.reduce((acc, item) => acc + (item.quantity * item.price), 0).toFixed(2) %></span>
                </div>
                <div class="flex justify-between text-sm text-gray-600">
                    <span>Delivery Cost</span>
                    <span>$<%= it.invoiceData.delivery_cost.toFixed(2) %></span>
                </div>
                <div class="border-t border-dashed border-gray-300 my-2"></div>
                <div class="flex justify-between text-lg font-bold text-gray-900">
                    <span>Total</span>
                    <span>$<%= it.invoiceData.totalAmount.toFixed(2) %></span>
                </div>
            </div>
        </section>
        <footer class="mt-12 text-center">
            <div
              id="qrcode"
              class="w-24 h-24 flex items-center justify-center border border-gray-200 p-1 rounded-lg mx-auto mb-4"
            ></div>
            <p class="text-sm text-gray-500">Thank you for your business!</p>
        </footer>
    </div>
    <script>
      const qrUrl =
        "<%= (typeof it !== 'undefined' && it.invoiceData && it.invoiceData.qr_url) ? it.invoiceData.qr_url : '' %>";
      if (qrUrl && document.getElementById("qrcode")) {
        new QRCode(document.getElementById("qrcode"), {
          text: qrUrl,
          width: 96,
          height: 96,
          colorDark: "#000000",
          colorLight: "#ffffff",
          correctLevel: QRCode.CorrectLevel.H,
        });
      }
    </script>
</body>
</html>