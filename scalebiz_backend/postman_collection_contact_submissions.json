              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"store_id\": 1,\n    \"full_name\": \"Jane Doe Updated\",\n    \"email\": \"jane.doe.updated@example.com\",\n    \"phone\": \"098-765-4321\",\n    \"subject\": \"Complaint about service updated\",\n    \"order_number\": \"ORDER-67890-UPDATED\",\n    \"message\": \"I am unhappy with the recent service. Please resolve this quickly.\",\n    \"status\": \"resolved\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/admin/contact-submissions/1",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "admin",
                "contact-submissions",
                "1"
              ]
            },
            "description": "Update a contact submission (admin access)"
          }
        },
        {
